{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the JAF Online, storing their profile information and role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the system (e.g., 'administrador', 'professor')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents a specific academic course or class within the school system.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "gradeLevel": {
          "type": "string"
        },
        "professorId": {
          "type": "string"
        },
        "studentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "year",
        "gradeLevel",
        "professorId",
        "studentIds",
        "createdAt",
        "updatedAt"
      ]
    },
    "SchoolSchedule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SchoolSchedule",
      "type": "object",
      "description": "Represents a class session in the weekly school schedule.",
      "properties": {
        "id": {
          "type": "string"
        },
        "courseId": {
          "type": "string",
          "description": "The course this schedule belongs to."
        },
        "dayOfWeek": {
          "type": "string",
          "enum": ["Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"]
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the class (HH:mm)."
        },
        "endTime": {
          "type": "string",
          "description": "End time of the class (HH:mm)."
        },
        "subject": {
          "type": "string",
          "description": "The subject name."
        },
        "teacherName": {
          "type": "string",
          "description": "Name of the teacher for this specific slot."
        }
      },
      "required": ["courseId", "dayOfWeek", "startTime", "endTime", "subject"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "enrollmentNumber": { "type": "string" },
        "enrollmentDate": { "type": "string", "format": "date" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "courseIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "enrollmentNumber", "enrollmentDate", "dateOfBirth", "courseIds", "createdAt", "updatedAt"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "recordedByProfessorId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "status", "studentId", "courseId", "recordedByProfessorId", "createdAt", "updatedAt"]
    },
    "MeetingAttendance": {
      "title": "MeetingAttendance",
      "type": "object",
      "description": "Represents the attendance of parents/guardians at school meetings.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "present": { "type": "boolean" },
        "observation": { "type": "string" },
        "recordedByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "courseId", "date", "present", "recordedByUserId", "createdAt", "updatedAt"]
    },
    "GradeRecord": {
      "title": "GradeRecord",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "number" },
        "activityName": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "recordedByProfessorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "value", "activityName", "date", "studentId", "courseId", "recordedByProfessorId", "createdAt", "updatedAt"]
    },
    "SchoolEvent": {
      "title": "SchoolEvent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "courseIds": { "type": "array", "items": { "type": "string" } },
        "createdByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "startDate", "endDate", "type", "createdByUserId", "createdAt", "updatedAt"]
    },
    "StudentHighlight": {
      "title": "StudentHighlight",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "generatedDate": { "type": "string", "format": "date-time" },
        "acknowledgedByProfessorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "type", "description", "generatedDate", "createdAt", "updatedAt"]
    },
    "GeneralNotice": {
      "title": "GeneralNotice",
      "type": "object",
      "description": "A global school notice shown on the dashboard.",
      "properties": {
        "text": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text"]
    },
    "RecommendedAction": {
      "title": "RecommendedAction",
      "type": "object",
      "description": "Recommended pedagogical or administrative actions for staff.",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["warning", "info"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "text", "type"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles.",
          "params": [{ "name": "userId" }]
        }
      },
      {
        "path": "/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": { "$ref": "#/backend/entities/Course" },
          "description": "Courses/classes.",
          "params": [{ "name": "courseId" }]
        }
      },
      {
        "path": "/schedules/{scheduleId}",
        "definition": {
          "entityName": "SchoolSchedule",
          "schema": { "$ref": "#/backend/entities/SchoolSchedule" },
          "description": "Weekly class schedules.",
          "params": [{ "name": "scheduleId" }]
        }
      },
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": { "$ref": "#/backend/entities/Student" },
          "description": "Student records.",
          "params": [{ "name": "studentId" }]
        }
      },
      {
        "path": "/attendanceRecords/{attendanceId}",
        "definition": {
          "entityName": "AttendanceRecord",
          "schema": { "$ref": "#/backend/entities/AttendanceRecord" },
          "description": "Attendance logs.",
          "params": [{ "name": "attendanceId" }]
        }
      },
      {
        "path": "/meetingAttendance/{attendanceId}",
        "definition": {
          "entityName": "MeetingAttendance",
          "schema": { "$ref": "#/backend/entities/MeetingAttendance" },
          "description": "Parent meeting attendance logs.",
          "params": [{ "name": "attendanceId" }]
        }
      },
      {
        "path": "/gradeRecords/{gradeId}",
        "definition": {
          "entityName": "GradeRecord",
          "schema": { "$ref": "#/backend/entities/GradeRecord" },
          "description": "Student grades.",
          "params": [{ "name": "gradeId" }]
        }
      },
      {
        "path": "/schoolEvents/{eventId}",
        "definition": {
          "entityName": "SchoolEvent",
          "schema": { "$ref": "#/backend/entities/SchoolEvent" },
          "description": "School events.",
          "params": [{ "name": "eventId" }]
        }
      },
      {
        "path": "/studentHighlights/{highlightId}",
        "definition": {
          "entityName": "StudentHighlight",
          "schema": { "$ref": "#/backend/entities/StudentHighlight" },
          "description": "AI student highlights.",
          "params": [{ "name": "highlightId" }]
        }
      },
      {
        "path": "/schoolSettings/{settingId}",
        "definition": {
          "entityName": "GeneralNotice",
          "schema": { "$ref": "#/backend/entities/GeneralNotice" },
          "description": "Global settings like the general notice.",
          "params": [{ "name": "settingId" }]
        }
      },
      {
        "path": "/recommendedActions/{actionId}",
        "definition": {
          "entityName": "RecommendedAction",
          "schema": { "$ref": "#/backend/entities/RecommendedAction" },
          "description": "List of recommended actions.",
          "params": [{ "name": "actionId" }]
        }
      }
    ]
  }
}
