
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
        getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('administrador');
    }

    function isProfessor() {
      return hasRole('professor');
    }

    function isStaff() {
      return isAdmin() || isProfessor();
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow list, get: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow list, get: if isSignedIn();
      allow create, update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow list, get: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /attendanceRecords/{attendanceId} {
      allow list, get: if isSignedIn();
      allow create, update: if isAdmin(); // Apenas administrador pode editar faltas
      allow delete: if isAdmin();
    }

    match /meetingAttendance/{attendanceId} {
      allow list, get: if isSignedIn();
      allow create, update: if isAdmin(); // Apenas administrador pode editar reuniões
      allow delete: if isAdmin();
    }

    match /gradeRecords/{gradeId} {
      allow list, get: if isSignedIn();
      allow create, update: if isAdmin(); // Apenas administrador pode editar notas
      allow delete: if isAdmin();
    }

    match /schoolEvents/{eventId} {
      allow list, get: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /studentHighlights/{highlightId} {
      allow list, get: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /schoolSettings/{settingId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /recommendedActions/{actionId} {
      allow list, get: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
